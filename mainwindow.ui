       <widget class="QLineEdit" name="weightLineEdit"/>
      </item>
     </layout>
    </item>

    <!-- Поиск пути -->
    <item>
     <layout class="QFormLayout" name="formLayoutFindPath">
      <item row="0" column="0">
       <widget class="QLabel" name="labelStart">
        <property name="text"><string>Начальная вершина:</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QComboBox" name="startComboBox"/>
