      <item>
       <widget class="QPushButton" name="setVerticesCountButton">
        <property name="text"><string>Установить</string></property>
       </widget>
      </item>
     </layout>
    </item>

    <!-- Добавление ребра -->
    <item>
     <layout class="QFormLayout" name="formLayoutAddEdge">
      <item row="0" column="0">
       <widget class="QLabel" name="labelFromEdge">
        <property name="text"><string>Откуда:</string></property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLineEdit" name="fromEdgeLineEdit"/>
      </item>
      <item row="1" column="0">
       <widget class="QLabel" name="labelToEdge">
        <property name="text"><string>Куда:</string></property>
       </widget>
      </item>
